# ==============================================================================
# Variáveis de Ambiente — Invoice Worker
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA faça commit do .env no repositório.
# ==============================================================================

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=faturas

# Captcha — "2captcha" | "anticaptcha" | "capsolver"
CAPTCHA_SERVICE=2captcha
CAPTCHA_API_KEY=sua_chave_api_aqui
CAPTCHA_TIMEOUT_SECONDS=120
CAPTCHA_MAX_RETRIES=3

# Proxy (opcional)
# PROXY_SERVER=http://user:pass@proxy.exemplo.com:8080

# Worker
POLLING_INTERVAL_SECONDS=15
WORKER_BATCH_SIZE=3
HEADLESS=true
INVOICE_MONTHS=12

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
